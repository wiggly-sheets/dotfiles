# APP GROUPS
BROWSERS="^(Orion|Safari|Helium|Zen|Tor Browser)$"
MAIL="^(Mail)$"
FILES="^(Bloom|Finder|FlowFinder)$"
NOTES="^(Notes|Obsidian|Calendar)$"
TERMINALS="^(iTerm2|Alacritty|Kitty|WezTerm|Terminal|Tabby|Ghostty)$"
CODE="^(BBEdit|VSCodium|Zed|CotEditor|Neovide)$"

# PIN APPS TO SPACES
SPACE_RULES=(
  "${BROWSERS}:browser"
  "${MAIL}:mail"
  "${FILES}:files"
  "${NOTES}:notes"
  "${TERMINALS}:terminal"
  "${CODE}:code"
)
for rule in "${SPACE_RULES[@]}"; do
  app="${rule%%:*}"
  space="${rule##*:}"
  yabai -m rule --add app="${app}" space="${space}"
done

# helper for float rules
yabai_rule() {
  yabai -m rule --add "$@"
  yabai -m rule --apply "$@"
}

