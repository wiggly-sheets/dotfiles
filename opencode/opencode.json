{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "./plugins/caveman/plugin.js",
    "@tarquinen/opencode-dcp@latest",
    "@dietrichgebert/ponytail"
  ],

  "shell": "zsh",
  "disabled_providers": [],
  "provider": {
    "freellmapi": {
      "name": "FreeLLMAPI",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:31415/v1"
      },
      "models": {
        "auto": {
          "name": "Auto"
        }
      }
    }
  },

  "lsp": true,

  "mcp": {
    "xcode": {
      "type": "local",
      "command": ["node", "/Users/zeb/dev/mcp-servers/xcode-mcp-server/dist/index.js"],
      "enabled": true,
      "environment": {
        "PROJECTS_BASE_DIR": "/Users/zeb/dev"
      }
    }
  }
}